{
  "cli": {
    "version": ">= 20.4.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {}
  }

  {
  "build": {
    "preview": {
      "env": {
        "EXPO_PROJECT_ROOT": "artifacts/mobile"
      }
    }
  }
}
