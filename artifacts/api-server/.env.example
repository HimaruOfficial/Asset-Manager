# ─── FinTrack API Server — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your credentials.
# Never commit .env to version control.

# Required: Express server port (set automatically by Replit)
PORT=5000

# ─── Telegram Bot Integration ─────────────────────────────────────────────────
# 1. Message @BotFather on Telegram → /newbot → follow prompts
# 2. Copy the token it gives you and paste it below
TELEGRAM_BOT_TOKEN=8621430072:AAHnEs9vAcVL_gL13tHKEliHoLx20bAz1ao

# (Optional) Admin's Telegram Chat ID — get yours by messaging @userinfobot
TELEGRAM_ADMIN_CHAT_ID=8593621016

# ─── Google Sheets Sync ───────────────────────────────────────────────────────
# Your Google Sheet ID — found in the sheet URL:
# https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
GOOGLE_SHEETS_ID=1xyYHshS-ZGuDlVglaN3LonBdW1wbynIGLePvjs2se7g

# (Option A) Google Apps Script Web App URL for writing data
# Deploy your Apps Script as a web app and paste the URL here
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/AKfycbxth2SGyWukF4TBbSk_LXSjwtz25gnLgYQnuoGAxF5LSDtZY65nUVbeqL9BSvJgKhsP/exec

# (Option B) Google Sheets API Key for reading data (via REST API)
# Create one at: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_SHEETS_API_KEY=